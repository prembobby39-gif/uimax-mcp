{
  "name": "uimax-mcp",
  "version": "0.3.0",
  "description": "UIMax MCP — Turns Claude Code into a frontend expert that reviews and fixes your UI automatically. Free for Pro plan users.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "uimax-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "!dist/__tests__/**"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ui-review",
    "accessibility",
    "frontend",
    "design-review",
    "web-audit",
    "axe-core",
    "puppeteer",
    "claude-code",
    "dark-mode",
    "uimax",
    "ui-expert"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "axe-core": "^4.10.0",
    "glob": "^11.0.0",
    "lighthouse": "^13.0.3",
    "puppeteer-core": "^24.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
